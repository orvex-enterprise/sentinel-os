{
  "$ref": "#/definitions/AuditRecord",
  "definitions": {
    "AuditRecord": {
      "type": "object",
      "properties": {
        "audit_id": {
          "type": "string",
          "format": "uuid"
        },
        "case_id": {
          "type": "string",
          "format": "uuid"
        },
        "actor": {
          "type": "string"
        },
        "action_performed": {
          "type": "string"
        },
        "previous_status": {
          "type": "string",
          "enum": [
            "DETECTED",
            "INVESTIGATING",
            "PLAN_GENERATED",
            "AWAITING_APPROVAL",
            "APPROVED",
            "EXECUTING",
            "EXECUTION_FAILED",
            "CLOSED_SUCCESS",
            "CLOSED_REJECTED",
            "CLOSED_FAILED"
          ]
        },
        "new_status": {
          "$ref": "#/definitions/AuditRecord/properties/previous_status"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "details": {
          "type": "object",
          "additionalProperties": {},
          "default": {}
        }
      },
      "required": [
        "audit_id",
        "case_id",
        "actor",
        "action_performed",
        "new_status",
        "timestamp"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}