# ==============================================================================
# Sentinel OS — Master Environment Configuration Template
# ==============================================================================
# Copy this file to .env or use defaults provided in docker-compose.yml.
# This template supports zero-cost, local-first execution via Ollama (DEV-001).

# ------------------------------------------------------------------------------
# 1. Database & Infrastructure (PostgreSQL + pgvector + Redis)
# ------------------------------------------------------------------------------
POSTGRES_DB=sentinel_db
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_secret
REDIS_PASSWORD=redis_secret

# ------------------------------------------------------------------------------
# 2. Service URLs & Ports
# ------------------------------------------------------------------------------
DATABASE_URL=postgres://sentinel:sentinel_secret@localhost:5432/sentinel_db
REDIS_URL=redis://:redis_secret@localhost:6379
GATEWAY_URL=http://localhost:4000
API_TOKEN_LIVE=tok_live_demo_8849201948210

# ------------------------------------------------------------------------------
# 3. AI & LangGraph Orchestration (DEV-001 / ADR-013 Zero-Cost Strategy)
# ------------------------------------------------------------------------------
# Provider Options: 'ollama' (local default), 'openai', 'groq', 'mock'
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Optional Cloud API Fallback Keys (Only required if LLM_PROVIDER is set to openai/groq)
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
