# ==============================================================================
# Sentinel OS — Orchestration Service Environment Configuration (.env.example)
# ==============================================================================
# Copy to .env for standalone LangGraph orchestration development.

PORT=5000
DATABASE_URL=postgres://sentinel:sentinel_secret@localhost:5432/sentinel_db
REDIS_URL=redis://:redis_secret@localhost:6379
GATEWAY_URL=http://localhost:4000

# Zero-Cost LLM Strategy (DEV-001)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Optional Cloud API Fallback Keys
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
